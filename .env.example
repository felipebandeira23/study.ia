# ============================================================
# StudyAI — Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env.local e preencha com seus valores
# NUNCA commite o arquivo .env.local com valores reais!
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard → Settings → API

# URL do projeto Supabase (segura para expor no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima/pública do Supabase (segura para expor no cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Chave de serviço do Supabase (NUNCA expor no cliente — somente server-side)
# Use apenas em Server Actions ou Route Handlers quando necessário
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-aqui

# ── Google AI Studio ──────────────────────────────────────────
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
# NUNCA expor esta chave no cliente — use apenas server-side

GOOGLE_AI_STUDIO_API_KEY=sua-api-key-aqui

# ── URL do Site ───────────────────────────────────────────────
# Em desenvolvimento: http://localhost:3000
# Em produção: sua URL da Vercel (ex: https://study-ia.vercel.app)

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── (Opcional) Configurações adicionais ──────────────────────
# NODE_ENV é definido automaticamente pelo Next.js
# NODE_ENV=development
